    "DinePick filters suggestions by drive time from where you are. Allow location access in the Settings app.": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "DinePick は現在地からの運転時間でおすすめを絞り込みます。「設定」アプリで位置情報へのアクセスを許可してください。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "DinePick 會依你目前位置的車程時間篩選建議。請在「設定」App 中允許取用定位。"
          }
